{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CorpusEntry",
  "description": "Schema for a single validated toke corpus entry. Version 1.",
  "version": 1,
  "type": "object",
  "required": ["id", "version", "phase", "task_id", "tk_source", "tk_tokens",
               "validation", "differential", "judge"],
  "properties": {
    "id":          { "type": "string", "description": "Unique corpus entry ID" },
    "version":     { "type": "integer", "description": "Schema version" },
    "phase":       { "type": "string", "enum": ["A", "B", "C"] },
    "task_id":     { "type": "string", "description": "Benchmark task ID" },
    "tk_source":   { "type": "string", "description": "Validated toke source code" },
    "tk_tokens":   { "type": "integer", "description": "Token count in cl100k_base" },
    "attempts":    { "type": "integer", "description": "Generation attempts before acceptance" },
    "model":       { "type": "string", "description": "Model that generated this entry" },
    "validation": {
      "type": "object",
      "required": ["compiler_exit_code", "error_codes"],
      "properties": {
        "compiler_exit_code": { "type": "integer" },
        "error_codes":        { "type": "array", "items": { "type": "string" } }
      }
    },
    "differential": {
      "type": "object",
      "required": ["languages_agreed", "majority_output"],
      "properties": {
        "languages_agreed": { "type": "array", "items": { "type": "string" } },
        "majority_output":  { "type": "string" }
      }
    },
    "judge": {
      "type": "object",
      "required": ["accepted", "score"],
      "properties": {
        "accepted": { "type": "boolean" },
        "score":    { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "references": {
      "type": "object",
      "properties": {
        "python_source": { "type": "string", "description": "Equivalent Python source" },
        "python_tokens": { "type": "integer", "description": "Python token count (cl100k_base)" },
        "c_source":      { "type": "string", "description": "Equivalent C source" },
        "c_tokens":      { "type": "integer", "description": "C token count (cl100k_base)" },
        "java_source":   { "type": "string", "description": "Equivalent Java source" },
        "java_tokens":   { "type": "integer", "description": "Java token count (cl100k_base)" }
      }
    }
  }
}
